{
  "name": "@bazaar/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -b ../../packages/core ../../packages/spacebase ../../packages/shopping ../../packages/agents .",
    "db:seed": "tsx src/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bazaar/agents": "file:../../packages/agents",
    "@bazaar/core": "file:../../packages/core",
    "@bazaar/shopping": "file:../../packages/shopping",
    "@bazaar/spacebase": "file:../../packages/spacebase",
    "@google-cloud/vision": "latest",
    "@hono/node-server": "latest",
    "@neondatabase/serverless": "latest",
    "dotenv": "latest",
    "hono": "latest",
    "nanoid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
