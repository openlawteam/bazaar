# =============================================================================
# APP
# =============================================================================

PORT=8787
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:8787

# =============================================================================
# LINQ MESSAGING
# =============================================================================

# Linq inbound webhook verification and outbound messaging.
# Greg owns the final provider payload/signature wiring.
LINQ_WEBHOOK_SECRET=
LINQ_API_KEY=
LINQ_API_BASE_URL=
LINQ_FROM_PHONE_NUMBER=
LINQ_OTP_TEMPLATE_ID=

# Optional private-demo guard for inbound SMS.
# If either list is populated, only those numbers can use the SMS route.
# Trusted numbers also bypass OTP and go straight to Bazaar want intake.
SMS_ALLOWED_PHONE_NUMBERS=
SMS_TRUSTED_PHONE_NUMBERS=

# =============================================================================
# AUTH / SESSIONS
# =============================================================================

# Used for phone auth sessions, OTP state, and signed cookies/tokens.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional controls for SMS OTP during local development.
OTP_CODE_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
NEXT_PUBLIC_DEMO_MODE=false

# =============================================================================
# DATABASE / CACHE
# =============================================================================

# PostgreSQL connection string. Neon works well for quick setup.
DATABASE_URL=
SHOPPING_USE_DATABASE=true
SHOPPING_MARKETPLACE_DEMO=true
SHOPPING_DEMO_MODE=true

# Optional Redis for OTP/session state, rate limits, and background jobs.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# AI / AGENTS
# =============================================================================

# ADIN public API key for streamed buying/profile assistance.
ADIN_API_BASE_URL=https://adin.chat/api/v1
ADIN_API_KEY=

# Optional direct model provider keys for local agent experiments.
OPENAI_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=

# Google Cloud Vision image intake. Local development can use Application
# Default Credentials, a service-account JSON path, or the same SKUNK_*
# service-account vars used by adin-chat.
GOOGLE_APPLICATION_CREDENTIALS=
SKUNK_PROJECT_ID=
SKUNK_CLIENT_EMAIL=
SKUNK_PRIVATE_KEY=

# Exa can power web/listing research if Jamie's adapters use web extraction.
EXA_API_KEY=
SHOPPING_LIVE_SEARCH=false

# =============================================================================
# SPACEBASE1 / INTENT SPACE
# =============================================================================

# Spacebase1 / intent-space bridge configuration.
SPACEBASE_COMMONS_URL=https://spacebase1.differ.ac/commons
SPACEBASE_AGENT_PRINCIPAL=
SPACEBASE_AGENT_LABEL=Bazaar
SPACEBASE_HOME_SPACE_ID=
SPACEBASE_HACKATHON_SUBMISSION_PARENT_ID=intent-413e0bc5-d8f3-40e7-afb4-350e220df03c

# =============================================================================
# SHOPPING SOURCES
# =============================================================================

# Jamie owns concrete source adapters. These are placeholders for likely first
# integrations and should stay empty until keys are provisioned.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=sandbox
GOOGLE_MAPS_API_KEY=

# =============================================================================
# PAYMENTS / PURCHASE APPROVALS
# =============================================================================

# Optional later: x402-style payment settings if buying flows need paid actions.
X402_PAY_TO=
X402_NETWORK=base
FACILITATOR_URL=https://x402.org/facilitator

# =============================================================================
# IOS
# =============================================================================

# Public API URL for Suvina's SwiftUI app in local/dev builds.
IOS_API_BASE_URL=http://localhost:8787
